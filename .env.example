# ─── Cloudflare D1 ───────────────────────────────────────────────────────────
# Used by wrangler for local D1 emulation during dev
# In production these are set in wrangler.toml or Cloudflare dashboard

# Your Cloudflare account ID (found in dashboard sidebar)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# D1 database ID (output from: wrangler d1 create taxonomy-db)
D1_DATABASE_ID=your_d1_database_id_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# CLOUDFLARE_API_TOKEN=your_api_token_here
